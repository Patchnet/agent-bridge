# Patchnet Agent Bridge — Configuration Template
# -------------------------------------------------------
# Copy this file to .env and fill in all values.
# Every value is unique to this deployment — no secrets
# are shared across deployments or stored in the repo.
# -------------------------------------------------------
# NEVER commit .env to git.

# ── Azure AD (unique per deployment) ──────────────────
# Tenant ID from Azure Active Directory → Overview
TENANT_ID=

# Application (client) ID from this deployment's app registration
CLIENT_ID=

# Client secret from this deployment's app registration
# Azure AD → App registrations → Certificates & secrets → New client secret
CLIENT_SECRET=

# ── Bot Account ────────────────────────────────────────
# OAuth2 refresh token for the bot user account.
# Generate once via the auth flow, then auto-rotates on every use.
# Bridge writes the new token back to this file on each refresh.
REFRESH_TOKEN=

# Entra object ID of the bot user account (NOT the app registration).
# Azure AD → Users → select bot account → Object ID
# Used to filter out the bot's own messages from the poll results.
BOT_USER_ID=

# ── OpenClaw Gateway ───────────────────────────────────
# WebSocket URL for the OpenClaw gateway (usually local)
OPENCLAW_URL=ws://127.0.0.1:18789

# Gateway auth token — must match gateway.auth.token in openclaw.json
OPENCLAW_TOKEN=

# Agent ID to route messages to (default: main)
OPENCLAW_AGENT_ID=main

# ── Logging ────────────────────────────────────────────
# Log level: full (all messages) or errors (errors and startup only)
LOG_LEVEL=full

# ── Polling ────────────────────────────────────────────
# How often to check Teams for new messages (milliseconds)
# 5000 = 5 seconds. Lower = faster response, more API calls.
POLL_INTERVAL_MS=5000

# ── Access Control ─────────────────────────────────────
# Comma-separated list of authorized users (UPN and/or Entra object ID).
# Use object IDs — UPNs can change, object IDs never do.
# Graph API sometimes omits UPN from message metadata — always include object ID.
# Leave empty to allow all users in the tenant (not recommended for production).
# Example: user@domain.com,00000000-0000-0000-0000-000000000000
ALLOWED_USERS=

# ── Email Integration ─────────────────────────────────
# Email mode: off (default), read, or full.
#   off  — email features disabled entirely
#   read — poll inbox, manage mailbox (move/delete/folders), no sending
#   full — everything in read + reply, compose, forward (all sends whitelist-gated)
# NOTE: Changing from "off" to "read" or "full" requires re-running the OAuth
# setup script to get a refresh token with Mail.ReadWrite (+ Mail.Send) scopes.
EMAIL_MODE=off

# Bot account email address — used to resolve '*' in the whitelist to the bot's domain.
BOT_EMAIL=

# How often to poll for new emails in full mode (milliseconds).
# 15000 = 15 seconds. Ignored when EMAIL_MODE is not "full".
EMAIL_POLL_INTERVAL_MS=15000

# Comma-separated whitelist for email send operations.
# Every recipient is checked before every send — code-level enforced.
# Formats:
#   user@example.com       — exact address
#   *@example.com          — entire domain
#   example.com            — same as *@example.com
#   *                      — bot's own domain only (requires BOT_EMAIL)
# Leave empty to block ALL outbound email (fail-safe).
# Example: *@patchnet.net,partner@external.com
EMAIL_WHITELIST=

# ── Teams Channels ───────────────────────────────────
# How often to poll channels for @mentions (milliseconds).
# 10000 = 10 seconds. Only polls teams in managed or open mode.
CHANNEL_POLL_INTERVAL_MS=10000

# Manager who controls channel modes and receives notifications
# when the bot is added to or removed from teams.
# Must also be in ALLOWED_USERS. Use UPN or Entra object ID.
CHANNEL_MANAGER=
